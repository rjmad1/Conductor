# EditorConfig configuration for Conductor Platform
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.java]
indent_size = 4

[*.{js,ts,jsx,tsx,json}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[*.py]
indent_size = 4
indent_style = space

[*.tf]
indent_size = 2

[Makefile]
indent_style = tab
indent_size = 4
